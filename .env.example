# Copy to `.env` in this directory (gitignored). Docker Compose reads `.env` automatically.
UK_ENERGY_DB_PASSWORD=choose_a_strong_password

# Optional: only if you are not using defaults in pipeline/config/settings.yaml
# UK_ENERGY_DB_HOST=localhost
# UK_ENERGY_DB_PORT=5432
# Host port when using `docker run -p 55432:5432` must match here, e.g. 55432.
# UK_ENERGY_DB_NAME=uk_energy
# Must match POSTGRES_USER in Docker (e.g. uk_energy_user from docker-compose.yml, or gogir if you created the container manually).
# UK_ENERGY_DB_USER=uk_energy_user
